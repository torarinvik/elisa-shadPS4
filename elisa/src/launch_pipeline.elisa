include "launch_intent.elisa"

permission HostLaunchPipeline:
    WaitForPid
    BootLog
    IPC
    EmulatorState
    UserSettings
    Config
    Keys
    EmulatorSettings
    UtilityCommand
    LaunchFlags
    ResolveGame
    StartEmulator
    Run

extern shadps4_elisa_wait_for_pid_exit(pid: int, poll_ms: u32, max_polls: i64) -> int can[LaunchNative.FFI, HostLaunchPipeline.WaitForPid]
extern shadps4_elisa_pipeline_setup_boot_log() -> int can[LaunchNative.FFI, HostLaunchPipeline.BootLog]
extern shadps4_elisa_pipeline_set_log_append() -> int can[LaunchNative.FFI, HostLaunchPipeline.BootLog]
extern shadps4_elisa_pipeline_initialize_ipc() -> int can[LaunchNative.FFI, HostLaunchPipeline.IPC]
extern shadps4_elisa_pipeline_initialize_emulator_state() -> int can[LaunchNative.FFI, HostLaunchPipeline.EmulatorState]
extern shadps4_elisa_pipeline_load_user_settings() -> int can[LaunchNative.FFI, HostLaunchPipeline.UserSettings]
extern shadps4_elisa_pipeline_load_config() -> int can[LaunchNative.FFI, HostLaunchPipeline.Config]
extern shadps4_elisa_pipeline_load_keys() -> int can[LaunchNative.FFI, HostLaunchPipeline.Keys]
extern shadps4_elisa_pipeline_load_emulator_settings() -> int can[LaunchNative.FFI, HostLaunchPipeline.EmulatorSettings]
extern shadps4_elisa_pipeline_restart_log_from_settings() -> int can[LaunchNative.FFI, HostLaunchPipeline.BootLog, HostLaunchPipeline.EmulatorSettings]
extern shadps4_elisa_pipeline_big_picture(executable_name: u8&) -> int can[LaunchNative.FFI, HostLaunchPipeline.UtilityCommand]
extern shadps4_elisa_pipeline_add_game_folder(path: u8&) -> int can[LaunchNative.FFI, HostLaunchPipeline.UtilityCommand]
extern shadps4_elisa_pipeline_set_addon_folder(path: u8&) -> int can[LaunchNative.FFI, HostLaunchPipeline.UtilityCommand]
extern shadps4_elisa_pipeline_set_patch_file(path: u8&) -> int can[LaunchNative.FFI, HostLaunchPipeline.LaunchFlags]
extern shadps4_elisa_pipeline_set_ignore_game_patch() -> int can[LaunchNative.FFI, HostLaunchPipeline.LaunchFlags]
extern shadps4_elisa_pipeline_set_fullscreen(enabled: int) -> int can[LaunchNative.FFI, HostLaunchPipeline.LaunchFlags]
extern shadps4_elisa_pipeline_set_show_fps() -> int can[LaunchNative.FFI, HostLaunchPipeline.LaunchFlags]
extern shadps4_elisa_pipeline_set_config_mode(mode: i64) -> int can[LaunchNative.FFI, HostLaunchPipeline.LaunchFlags]
extern shadps4_elisa_pipeline_resolve_game_path(game_path: u8&) -> cstr can[LaunchNative.FFI, HostLaunchPipeline.ResolveGame]
extern shadps4_elisa_pipeline_run_emulator(executable_name: u8&, wait_for_debugger: int, resolved_game_path: cstr, argc: i64, argv: u8&&, game_arg_start_index: i64, game_arg_count: i64, override_root: u8&) -> int can[LaunchNative.FFI, HostLaunchPipeline.StartEmulator]

module LaunchPipeline:
    def bool_to_int(value: int) -> int:
        return 1 if value != 0 else 0

    def run_wait_for_pid(intent: mutable ShadLaunchIntentCABI&) -> int can[LaunchNative.FFI, HostLaunchPipeline.WaitForPid]:
        if intent.has_wait_pid == 0:
            return 1
        can LaunchNative.FFI, HostLaunchPipeline.WaitForPid:
            return shadps4_elisa_wait_for_pid_exit(intent.wait_pid.int(), 500, 7200)

    def initialize_runtime_settings(intent: mutable ShadLaunchIntentCABI&) -> int can[LaunchNative.FFI, HostLaunchPipeline.BootLog, HostLaunchPipeline.IPC, HostLaunchPipeline.EmulatorState, HostLaunchPipeline.UserSettings, HostLaunchPipeline.Config, HostLaunchPipeline.Keys, HostLaunchPipeline.EmulatorSettings]:
        can LaunchNative.FFI, HostLaunchPipeline.BootLog:
            if intent.log_append != 0:
                _ = shadps4_elisa_pipeline_set_log_append()
            if shadps4_elisa_pipeline_setup_boot_log() == 0:
                return 0
        can LaunchNative.FFI, HostLaunchPipeline.IPC:
            if shadps4_elisa_pipeline_initialize_ipc() == 0:
                return 0
        can LaunchNative.FFI, HostLaunchPipeline.EmulatorState:
            if shadps4_elisa_pipeline_initialize_emulator_state() == 0:
                return 0
        can LaunchNative.FFI, HostLaunchPipeline.UserSettings:
            if shadps4_elisa_pipeline_load_user_settings() == 0:
                return 0
        can LaunchNative.FFI, HostLaunchPipeline.Config:
            if shadps4_elisa_pipeline_load_config() == 0:
                return 0
        can LaunchNative.FFI, HostLaunchPipeline.Keys:
            if shadps4_elisa_pipeline_load_keys() == 0:
                return 0
        can LaunchNative.FFI, HostLaunchPipeline.EmulatorSettings:
            if shadps4_elisa_pipeline_load_emulator_settings() == 0:
                return 0
        can LaunchNative.FFI, HostLaunchPipeline.BootLog, HostLaunchPipeline.EmulatorSettings:
            if shadps4_elisa_pipeline_restart_log_from_settings() == 0:
                return 0
        return 1

    def handle_utility_command(executable_name: u8&, intent: mutable ShadLaunchIntentCABI&) -> int can[LaunchNative.FFI, HostLaunchPipeline.UtilityCommand]:
        can LaunchNative.FFI, HostLaunchPipeline.UtilityCommand:
            if intent.kind == SHAD::LAUNCH_KIND_BIG_PICTURE:
                return shadps4_elisa_pipeline_big_picture(executable_name)
            if intent.kind == SHAD::LAUNCH_KIND_ADD_GAME_FOLDER:
                return shadps4_elisa_pipeline_add_game_folder(intent.add_game_folder)
            if intent.kind == SHAD::LAUNCH_KIND_SET_ADDON_FOLDER:
                return shadps4_elisa_pipeline_set_addon_folder(intent.set_addon_folder)
        return -1

    def apply_launch_flags(intent: mutable ShadLaunchIntentCABI&) -> int can[LaunchNative.FFI, HostLaunchPipeline.LaunchFlags]:
        can LaunchNative.FFI, HostLaunchPipeline.LaunchFlags:
            if not shad_launch_streq(intent.patch_file.cast[cstr], ""):
                if shadps4_elisa_pipeline_set_patch_file(intent.patch_file) == 0:
                    return 0
            if intent.ignore_game_patch != 0:
                if shadps4_elisa_pipeline_set_ignore_game_patch() == 0:
                    return 0
            if intent.fullscreen == SHAD::FULLSCREEN_TRUE:
                if shadps4_elisa_pipeline_set_fullscreen(1) == 0:
                    return 0
            elif intent.fullscreen == SHAD::FULLSCREEN_FALSE:
                if shadps4_elisa_pipeline_set_fullscreen(0) == 0:
                    return 0
            elif intent.fullscreen == SHAD::FULLSCREEN_INVALID:
                return 0
            if intent.show_fps != 0:
                if shadps4_elisa_pipeline_set_show_fps() == 0:
                    return 0
            if intent.config_mode == SHAD::CONFIG_CLEAN:
                if shadps4_elisa_pipeline_set_config_mode(SHAD::CONFIG_CLEAN) == 0:
                    return 0
            elif intent.config_mode == SHAD::CONFIG_GLOBAL:
                if shadps4_elisa_pipeline_set_config_mode(SHAD::CONFIG_GLOBAL) == 0:
                    return 0
            elif intent.config_mode == SHAD::CONFIG_CONFLICT:
                return 0
        return 1

    def resolve_game_path(intent: mutable ShadLaunchIntentCABI&) -> cstr can[LaunchNative.FFI, HostLaunchPipeline.ResolveGame]:
        can LaunchNative.FFI, HostLaunchPipeline.ResolveGame:
            return shadps4_elisa_pipeline_resolve_game_path(intent.game_path)

    def run_emulator(executable_name: u8&, argc: i64, argv: u8&&, intent: mutable ShadLaunchIntentCABI&, resolved_game_path: cstr) -> int can[LaunchNative.FFI, HostLaunchPipeline.StartEmulator]:
        can LaunchNative.FFI, HostLaunchPipeline.StartEmulator:
            return shadps4_elisa_pipeline_run_emulator(
                executable_name,
                LaunchPipeline::bool_to_int(intent.wait_for_debugger),
                resolved_game_path,
                argc,
                argv,
                intent.game_arg_start_index,
                intent.game_arg_count,
                intent.override_root
            )

    def run_parsed_launch(executable_name: u8&, argc: i64, argv: u8&&, intent: mutable ShadLaunchIntentCABI&) -> int can[LaunchNative.FFI, HostLaunchPipeline.WaitForPid, HostLaunchPipeline.BootLog, HostLaunchPipeline.IPC, HostLaunchPipeline.EmulatorState, HostLaunchPipeline.UserSettings, HostLaunchPipeline.Config, HostLaunchPipeline.Keys, HostLaunchPipeline.EmulatorSettings, HostLaunchPipeline.UtilityCommand, HostLaunchPipeline.LaunchFlags, HostLaunchPipeline.ResolveGame, HostLaunchPipeline.StartEmulator]:
        can LaunchNative.FFI, HostLaunchPipeline.WaitForPid:
            _ = LaunchPipeline::run_wait_for_pid(intent)

        can LaunchNative.FFI, HostLaunchPipeline.BootLog, HostLaunchPipeline.IPC, HostLaunchPipeline.EmulatorState, HostLaunchPipeline.UserSettings, HostLaunchPipeline.Config, HostLaunchPipeline.Keys, HostLaunchPipeline.EmulatorSettings:
            if LaunchPipeline::initialize_runtime_settings(intent) == 0:
                return 1

        if intent.kind == SHAD::LAUNCH_KIND_BIG_PICTURE or intent.kind == SHAD::LAUNCH_KIND_ADD_GAME_FOLDER or intent.kind == SHAD::LAUNCH_KIND_SET_ADDON_FOLDER:
            can LaunchNative.FFI, HostLaunchPipeline.UtilityCommand:
                utility_result: int = LaunchPipeline::handle_utility_command(executable_name, intent)
                return 0 if utility_result != 0 else 1

        can LaunchNative.FFI, HostLaunchPipeline.LaunchFlags:
            if LaunchPipeline::apply_launch_flags(intent) == 0:
                return 1

        resolved_game_path: mutable cstr = ""
        can LaunchNative.FFI, HostLaunchPipeline.ResolveGame:
            resolved_game_path <- LaunchPipeline::resolve_game_path(intent)
        if shad_launch_streq(resolved_game_path, ""):
            return 1

        can LaunchNative.FFI, HostLaunchPipeline.StartEmulator:
            return LaunchPipeline::run_emulator(executable_name, argc, argv, intent, resolved_game_path)
