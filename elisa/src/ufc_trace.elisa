permission Sys:
    FFI

permission SysProcess:
    Spawn
    Kill

permission SysEnv:
    Write

permission SysMemory:
    Read
    Foreign

permission FS:
    Read
    Write

permission Clock:
    Read

extern shadps4_elisa_find_ufc1(out_path: mutable u8&, out_path_cap: u64) -> int can[Sys.FFI, FS.Read]
extern shadps4_elisa_run_ufc_trace(root_dir: cstr, profile: cstr, timeout_ms: u32, out_log_path: mutable u8&, out_log_path_cap: u64, out_exit_code: mutable int&, out_timed_out: mutable int&) -> int can[Sys.FFI, SysProcess.Spawn, SysProcess.Kill, SysEnv.Write, FS.Write, Clock.Read]
extern shadps4_elisa_run_ufc_trace_flags(root_dir: cstr, profile: cstr, timeout_ms: u32, null_fmask_reads: int, fmask_decompress_in_place: int, compositor_null_layer: int, videoout_unorm: int, out_log_path: mutable u8&, out_log_path_cap: u64, out_exit_code: mutable int&, out_timed_out: mutable int&) -> int can[Sys.FFI, SysProcess.Spawn, SysProcess.Kill, SysEnv.Write, FS.Write, Clock.Read]
extern shadps4_elisa_read_file(path: cstr) -> cstr can[Sys.FFI, FS.Read, SysMemory.Foreign]
extern shadps4_elisa_last_log_path() -> cstr can[Sys.FFI]
extern shadps4_elisa_last_error() -> cstr can[Sys.FFI]
extern printf(format: u8&, ...) -> int can[Console.Write]

struct GameId:
    text: cstr

struct TraceProfile:
    name: cstr
    timeout_ms: u32
    null_fmask_reads: bool
    fmask_decompress_in_place: bool
    compositor_null_layer: bool
    videoout_unorm: bool

struct TraceRun:
    game: GameId
    profile: TraceProfile
    log_path: cstr
    exit_code: int
    timed_out: bool

struct TraceResult:
    ok: bool
    run: TraceRun
    render: RenderCheckpoint
    error_message: cstr

