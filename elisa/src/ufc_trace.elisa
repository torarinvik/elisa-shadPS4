struct FmaskRisk:
    score: i64
    level: i64
    label: cstr
    reason: cstr
    recommended_profile: TraceProfile
    avoid_long_run: bool

struct FmaskMetadataClass:
    kind: i64
    label: cstr
    reason: cstr
    suspicious: bool

struct BlackScreenDiagnosis:
    kind: i64
    label: cstr
    reason: cstr
    likely_origin: cstr
    last_writer_label: cstr
    recommended_action: cstr
    avoid_long_run: bool

def metadata_kind_unknown() -> i64:
    return 0

def metadata_kind_fmask() -> i64:
    return 1

def metadata_kind_cmask() -> i64:
    return 2

def metadata_kind_htile() -> i64:
    return 3

def render_format_unknown() -> i64:
    return 0

def render_format_b10g11r11() -> i64:
    return 1

def render_format_d32s8() -> i64:
    return 2

def render_format_rgba8_unorm() -> i64:
    return 3

def render_format_rgba8_srgb() -> i64:
    return 4

def render_format_r16_sfloat() -> i64:
    return 5

def render_format_rg16_sfloat() -> i64:
    return 6

def render_format_r32_sfloat() -> i64:
    return 7

def fmask_risk_low() -> i64:
    return 0

def fmask_risk_medium() -> i64:
    return 1

def fmask_risk_high() -> i64:
    return 2

def fmask_metadata_absent() -> i64:
    return 0

def fmask_metadata_separate() -> i64:
    return 1

def fmask_metadata_aliased() -> i64:
    return 2

def fmask_metadata_single_sample_alias() -> i64:
    return 3

def fmask_metadata_single_sample_present() -> i64:
    return 4

def black_watchdog_stage_unknown() -> i64:
    return 0

def black_watchdog_stage_gameonly() -> i64:
    return 1

def black_watchdog_stage_frameimage() -> i64:
    return 2

def black_watchdog_stage_withoverlays() -> i64:
    return 3

def black_watchdog_writer_unknown() -> i64:
    return 0

def black_watchdog_writer_bind_storage_videoout() -> i64:
    return 1

def black_watchdog_writer_fill_buffer() -> i64:
    return 2

def black_watchdog_writer_copy_buffer_dst() -> i64:
    return 3

def black_watchdog_writer_copy_buffer_src() -> i64:
    return 4

def black_watchdog_writer_invalidate_gpu() -> i64:
    return 5

def black_screen_kind_absent() -> i64:
    return 0

def black_screen_kind_upstream_guest_black() -> i64:
    return 1

def black_screen_kind_vulkan_source_black() -> i64:
    return 2

def black_screen_kind_compositor_or_swapchain() -> i64:
    return 3

def black_screen_kind_watchdog_abort() -> i64:
