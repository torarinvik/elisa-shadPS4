    image_binding_null_count: mutable i64
    image_binding_texture_count: mutable i64
    image_binding_storage_count: mutable i64
    image_binding_videoout_storage_count: mutable i64
    compositor_null_layer_count: mutable i64
    fmask_decompress_missing_mrt1_count: mutable i64
    null_metadata_action_count: mutable i64
    sample_metadata_action_count: mutable i64
    fmask_cmask_alias_count: mutable i64
    metadata_read_hits_last_fmask_count: mutable i64
    metadata_read_hits_last_cmask_count: mutable i64
    metadata_read_hits_last_htile_count: mutable i64
    last_fmask_addr: mutable i64
    last_cmask_addr: mutable i64
    last_htile_addr: mutable i64
    last_metadata_read_addr: mutable i64
    last_metadata_read_kind: mutable i64
    last_render_samples: mutable i64
    last_depth_samples: mutable i64
    last_render_bits: mutable i64
    last_depth_bits: mutable i64
    last_render_format_kind: mutable i64
    last_depth_format_kind: mutable i64
    last_compute_shader: mutable i64
    last_vertex_shader: mutable i64
    last_graphics_pipeline: mutable i64
    last_compute_pipeline: mutable i64
    last_image_binding_id: mutable i64
    last_image_binding_index: mutable i64
    last_image_binding_stage: mutable i64
    last_image_binding_addr: mutable i64
    last_image_binding_bits: mutable i64
    last_image_binding_samples: mutable i64
    last_image_binding_format_kind: mutable i64
    launch_build_cache_warning_count: mutable i64
    launch_binary_current_count: mutable i64
    gpu_diagnostic_dump_count: mutable i64
    gpu_command_count: mutable i64
    gpu_command_draw_count: mutable i64
    gpu_command_indexed_draw_count: mutable i64
    gpu_command_indirect_draw_count: mutable i64
    gpu_command_dispatch_count: mutable i64
    gpu_command_swapchain_count: mutable i64
    last_gpu_command_serial: mutable i64
    last_gpu_draw_vertices: mutable i64
    last_gpu_draw_indices: mutable i64
    last_gpu_dispatch_x: mutable i64
    last_gpu_dispatch_y: mutable i64
    last_gpu_dispatch_z: mutable i64
    suspicious_score: mutable i64
    first_suspicious_pass: mutable i64
    screenshot_count: mutable i64
    dark_screenshot_count: mutable i64
    bright_screenshot_count: mutable i64
    last_screenshot_avg_luma_x100: mutable i64
    last_screenshot_max_luma: mutable i64
    last_screenshot_near_black_pct_x100: mutable i64
