    max_screenshot_avg_luma_x100: mutable i64
    black_watchdog_count: mutable i64
    black_watchdog_gameonly_count: mutable i64
    black_watchdog_frameimage_count: mutable i64
    black_watchdog_withoverlays_count: mutable i64
    black_watchdog_black_count: mutable i64
    black_watchdog_nonblack_gameonly_count: mutable i64
    black_watchdog_persistent_abort_count: mutable i64
    black_watchdog_upstream_guest_black_count: mutable i64
    black_watchdog_vulkan_black_guest_nonblack_count: mutable i64
    last_black_watchdog_stage: mutable i64
