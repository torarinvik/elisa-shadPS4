include "ufc_trace.elisa"


def main() -> int:
    result: mutable TraceResult = zeroed
    can Clock.Read, FS.Read, FS.Write, Sys.FFI, SysEnv.Write, SysMemory.Foreign, SysProcess.Kill, SysProcess.Spawn:
        result <- ufc_trace_run_baseline_safe("../shadPS4")
    can Console.Write:
        ufc_trace_print_summary(result)
    if not result.ok:
        return 1
    return 0
