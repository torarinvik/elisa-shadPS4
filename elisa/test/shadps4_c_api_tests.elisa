include "../src/ufc_trace.elisa"
include "../src/launch_intent.elisa"
include "ufc_trace_fixture.elisa"

extern shadps4_elisa_probe_value() -> i64


@test
def shadps4_c_api_probe_value_round_trips() -> void can[Abort.Panic]:
    can Abort.Panic:
        probe_value: mutable i64 = 0
        trusted Unsafe.RawExtern:
            probe_value <- shadps4_elisa_probe_value()
        if probe_value != 4242:
            panic("expected shadPS4 C API probe value")


@test
def launch_intent_no_args_matches_main_cpp_policy() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(1, "shadps4", "", "", "", "", "", "", "", "", "", "", "", "")
        if not intent.ok:
            panic("expected no-args intent to be ok")
        if intent.kind != SHAD::LAUNCH_KIND_NO_ARGS:
            panic("expected no-args intent kind")
        if intent.exit_code != -1:
            panic("expected no-args exit code")


@test
def launch_intent_parses_run_flags() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(9, "shadps4", "-g", "CUSA00264", "-p", "patch.toml", "-f", "true", "--show-fps", "--ignore-game-patch", "", "", "", "")
        if not intent.ok:
            panic("expected run intent to be ok")
        if intent.kind != SHAD::LAUNCH_KIND_RUN:
            panic("expected run intent")
        if not shad_launch_streq(intent.game_path, "CUSA00264"):
            panic("expected game path")
        if not shad_launch_streq(intent.patch_file, "patch.toml"):
            panic("expected patch file")
        if intent.fullscreen != SHAD::FULLSCREEN_TRUE:
            panic("expected fullscreen true")
        if not intent.show_fps:
            panic("expected show fps")
        if not intent.ignore_game_patch:
            panic("expected ignore game patch")


@test
def launch_intent_parses_help_without_game_resolution() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(2, "shadps4", "--help", "", "", "", "", "", "", "", "", "", "", "")
        if not intent.ok:
            panic("expected help intent to be ok")
        if intent.kind != SHAD::LAUNCH_KIND_HELP:
            panic("expected help intent kind")
        if intent.exit_code != 0:
            panic("expected help exit code")


@test
def launch_intent_accepts_positional_game_path_like_main_cpp() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(4, "shadps4", "CUSA00264", "--show-fps", "--ignore-game-patch", "", "", "", "", "", "", "", "", "")
        if not intent.ok:
            panic("expected positional game path intent to be ok")
        if intent.kind != SHAD::LAUNCH_KIND_RUN:
            panic("expected positional game path run intent")
        if not shad_launch_streq(intent.game_path, "CUSA00264"):
            panic("expected positional game path")
        if not intent.show_fps:
            panic("expected positional launch to preserve show fps")
        if not intent.ignore_game_patch:
            panic("expected positional launch to preserve ignore game patch")


@test
def launch_intent_parses_utility_commands_before_run() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(3, "shadps4", "--add-game-folder", "/games", "", "", "", "", "", "", "", "", "", "")
        if not intent.ok:
            panic("expected add-game-folder intent to be ok")
        if intent.kind != SHAD::LAUNCH_KIND_ADD_GAME_FOLDER:
            panic("expected add-game-folder kind")
        if not shad_launch_streq(intent.add_game_folder, "/games"):
            panic("expected add-game-folder path")


@test
def launch_intent_export_validates_add_game_folder_directory() -> void can[Abort.Panic, LaunchFS.Read, LaunchNative.FFI]:
    can Abort.Panic:
        args: u8&[4] = ["shadps4", "--add-game-folder", "/definitely/not/a/shadps4/folder", ""]
        out: mutable ShadLaunchIntentFFI = shad_launch_to_ffi(shad_launch_no_args("shadps4"))
        can LaunchNative.FFI, LaunchFS.Read:
            if shadps4_elisa_parse_launch_intent_impl(3, (&args[0]).cast[u8&&], out.ref[mutable ShadLaunchIntentFFI&]) == 0:
                panic("expected launch intent export to succeed")
        if out.ok != 0:
            panic("expected missing add-game-folder directory to fail in Elisa")
        if out.kind != SHAD::LAUNCH_KIND_ERROR:
            panic("expected missing add-game-folder directory to return error kind")
        if not shad_launch_streq(out.error_message.cast[cstr], "--add-game-folder: Directory does not exist"):
            panic("expected add-game-folder directory error")


@test
def launch_intent_export_accepts_existing_override_root_directory() -> void can[Abort.Panic, LaunchFS.Read, LaunchNative.FFI]:
    can Abort.Panic:
        args: u8&[6] = ["shadps4", "-g", "CUSA00264", "--override-root", ".", ""]
        out: mutable ShadLaunchIntentFFI = shad_launch_to_ffi(shad_launch_no_args("shadps4"))
        can LaunchNative.FFI, LaunchFS.Read:
            if shadps4_elisa_parse_launch_intent_impl(5, (&args[0]).cast[u8&&], out.ref[mutable ShadLaunchIntentFFI&]) == 0:
                panic("expected launch intent export to succeed")
        if out.ok == 0:
            panic("expected existing override-root directory to pass")
        if out.kind != SHAD::LAUNCH_KIND_RUN:
            panic("expected existing override-root to keep run kind")
        if not shad_launch_streq(out.override_root.cast[cstr], "."):
            panic("expected override-root path to round trip")


@test
def launch_intent_rejects_invalid_fullscreen() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(5, "shadps4", "-g", "CUSA00264", "--fullscreen", "maybe", "", "", "", "", "", "", "", "")
        if intent.ok:
            panic("expected invalid fullscreen to fail")
        if intent.kind != SHAD::LAUNCH_KIND_ERROR:
            panic("expected error kind")
        if not shad_launch_streq(intent.game_path, "CUSA00264"):
            panic("expected invalid fullscreen to preserve parsed game path like main.cpp")


@test
def launch_intent_tracks_game_args_after_double_dash() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(6, "shadps4", "-g", "CUSA00264", "--", "--guest-flag", "value", "", "", "", "", "", "", "")
        if not intent.ok:
            panic("expected run intent to be ok")
        if intent.game_arg_count != 2:
            panic("expected two guest args")
        if not shad_launch_streq(intent.first_game_arg, "--guest-flag"):
            panic("expected first guest arg")


@test
def launch_intent_config_global_wins_like_main_cpp() -> void can[Abort.Panic]:
    can Abort.Panic:
        intent: ShadLaunchIntent = shad_launch_parse_test_args(5, "shadps4", "-g", "CUSA00264", "--config-clean", "--config-global", "", "", "", "", "", "", "", "")
        if not intent.ok:
            panic("expected config conflict shape to follow C++ last-write policy")
        if intent.config_mode != SHAD::CONFIG_GLOBAL:
            panic("expected config global to win")


@test
def ufc_trace_parser_summarizes_render_checkpoints() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_FIXTURE)
        if summary.bindings.image_binding_count != 1:
            panic("expected one image binding")
        if summary.passes.render_target_count != 1:
            panic("expected one render target")
        if summary.passes.depth_target_count != 1:
            panic("expected one depth target")
        if summary.metadata.fmask_decompress_count != 1:
            panic("expected one fmask decompress event")
        if summary.metadata.metadata_texture_read_count != 1:
            panic("expected one metadata texture read")
        if summary.metadata.fmask_texture_read_count != 1:
            panic("expected one fmask metadata read")
        if summary.metadata.cmask_texture_read_count != 0:
            panic("expected no cmask metadata reads")
        if summary.metadata.htile_texture_read_count != 0:
            panic("expected no htile metadata reads")
        if summary.metadata.unknown_metadata_read_count != 0:
            panic("expected no unknown metadata reads")
        if summary.metadata.metadata_register_count != 1:
            panic("expected one metadata register")
        if summary.bindings.image_binding_texture_count != 1:
            panic("expected one texture image binding")
        if summary.bindings.image_binding_storage_count != 0:
            panic("expected no storage image bindings")
        if summary.bindings.image_binding_videoout_storage_count != 0:
            panic("expected no videoout storage image bindings")
        if summary.bindings.last_image_binding_id != 5:
            panic("expected last image binding id")
        if summary.bindings.last_image_binding_index != 0:
            panic("expected last image binding index")
        if summary.bindings.last_image_binding_stage != 1:
            panic("expected last image binding stage")
        if summary.bindings.last_image_binding_addr != 0x281120000:
            panic("expected last image binding address")
        if summary.bindings.last_image_binding_format_kind != render_format_rgba8_unorm():
            panic("expected last image binding format")
        if summary.bindings.last_image_binding_samples != 1:
            panic("expected last image binding samples")
        if summary.bindings.last_image_binding_bits != 32:
            panic("expected last image binding bits")
        if summary.passes.last_videoout_stage != 18:
            panic("expected videoout stage 18")
        if summary.passes.last_render_pass != 2160:
            panic("expected render pass 2160")
        if summary.passes.last_depth_pass != 2160:
            panic("expected depth pass 2160")
        if summary.metadata.last_fmask_addr != 0x2760f8000:
            panic("expected fmask address")
        if summary.metadata.last_cmask_addr != 0x2760f0000:
            panic("expected cmask address")
        if summary.metadata.last_htile_addr != 0x272ff0000:
            panic("expected htile address")
        if summary.metadata.last_metadata_read_addr != 0x2760f8000:
            panic("expected metadata read address")
        if summary.metadata.last_metadata_read_kind != metadata_kind_fmask():
            panic("expected fmask metadata kind")
        if summary.passes.last_render_samples != 4:
            panic("expected render sample count")
        if summary.passes.last_depth_samples != 4:
            panic("expected depth sample count")
        if summary.passes.last_render_bits != 32:
            panic("expected render bit depth")
        if summary.passes.last_depth_bits != 32:
            panic("expected depth bit depth")
        if summary.passes.last_render_format_kind != render_format_b10g11r11():
            panic("expected render format kind")
        if summary.passes.last_depth_format_kind != render_format_d32s8():
            panic("expected depth format kind")
        if summary.pipeline.last_compute_shader != 0xc455a5aa2c447041:
            panic("expected compute shader hash")
        if summary.pipeline.last_vertex_shader != 0x1198feb92f4085c4:
            panic("expected vertex shader hash")
        if summary.pipeline.last_compute_pipeline != 0xa2ca58b5abbba0fc:
            panic("expected compute pipeline hash")
        if summary.pipeline.last_graphics_pipeline != 0x8274a52bcc15679:
            panic("expected graphics pipeline hash")
        if summary.metadata.metadata_read_hits_last_fmask_count != 1:
            panic("expected metadata read to hit last fmask")
        if summary.metadata.metadata_read_hits_last_cmask_count != 0:
            panic("expected metadata read to miss last cmask")
        if summary.metadata.metadata_read_hits_last_htile_count != 0:
            panic("expected metadata read to miss last htile")
        if summary.metadata.fmask_cmask_alias_count != 0:
            panic("expected no fmask/cmask alias in fixture")
        if summary.suspicion.suspicious_score != 0:
            panic("expected no suspicious score in baseline fixture")
        risk: FmaskRisk = ufc_trace_fmask_risk(summary)
        if risk.level != fmask_risk_medium():
            panic("expected baseline fixture to be medium risk because fmask is sampled")
        if risk.score != 2:
            panic("expected baseline fixture risk score")
        if risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected fmask null-read recommendation")
        if not risk.avoid_long_run:
            panic("expected medium-risk trace to avoid long automated runs")


@test
def ufc_trace_parser_marks_black_screen_adjacent_suspicion() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_SUSPICIOUS_FIXTURE)
        if summary.passes.render_target_count != 1:
            panic("expected one suspicious render target")
        if summary.metadata.fmask_cmask_alias_count != 1:
            panic("expected aliased fmask/cmask")
        if summary.metadata.fmask_decompress_missing_mrt1_count != 1:
            panic("expected missing mrt1 decompress")
        if summary.bindings.compositor_null_layer_count != 1:
            panic("expected compositor null layer")
        if summary.bindings.image_binding_null_count != 1:
            panic("expected null image binding")
        if summary.metadata.null_metadata_action_count != 1:
            panic("expected null metadata action")
        if summary.metadata.metadata_read_hits_last_fmask_count != 1:
            panic("expected null metadata read to hit fmask")
        if summary.suspicion.first_suspicious_pass != 3000:
            panic("expected first suspicious pass")
        if summary.suspicion.suspicious_score < 5:
            panic("expected multiple suspicious signals")
        risk: FmaskRisk = ufc_trace_fmask_risk(summary)
        if risk.level != fmask_risk_high():
            panic("expected high fmask risk")
        if risk.score < 10:
            panic("expected high fmask risk score")
        if risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected fmask null-read recommendation for metadata hit")
        if not risk.avoid_long_run:
            panic("expected high-risk trace to avoid long automated runs")


@test
def ufc_trace_parser_summarizes_gpu_command_diagnostics() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_GPU_DIAGNOSTIC_FIXTURE)
        if summary.launch.launch_build_cache_warning_count != 1:
            panic("expected one stale build cache warning")
        if summary.launch.launch_binary_current_count != 1:
            panic("expected current build binary marker")
        if summary.gpu.gpu_diagnostic_dump_count != 1:
            panic("expected one gpu diagnostic dump")
        if summary.gpu.gpu_command_count != 4:
            panic("expected four gpu command lines")
        if summary.gpu.gpu_command_swapchain_count != 1:
            panic("expected one swapchain gpu command")
        if summary.gpu.gpu_command_draw_count != 2:
            panic("expected two draw commands")
        if summary.gpu.gpu_command_indexed_draw_count != 1:
            panic("expected one indexed draw command")
        if summary.gpu.gpu_command_indirect_draw_count != 0:
            panic("expected no indirect draw command")
        if summary.gpu.gpu_command_dispatch_count != 1:
            panic("expected one dispatch command")
        if summary.gpu.last_gpu_command_serial != 12:
            panic("expected last gpu command serial")
        if summary.gpu.last_gpu_draw_vertices != 6:
            panic("expected last direct draw vertex count")
        if summary.gpu.last_gpu_draw_indices != 42:
            panic("expected last indexed draw index count")
        if summary.gpu.last_gpu_dispatch_x != 16:
            panic("expected last dispatch x")
        if summary.gpu.last_gpu_dispatch_y != 8:
            panic("expected last dispatch y")
        if summary.gpu.last_gpu_dispatch_z != 1:
            panic("expected last dispatch z")


@test
def ufc_trace_parser_summarizes_screenshot_stats() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text("[Render.Vulkan] <Info> vk_presenter.cpp:501 LogScreenshotStats: TRACE_SCREENSHOT path=/tmp/bright.png size=1920x1080 avg_luma=200.92 max_luma=255 near_black=0.00%\n[Render.Vulkan] <Info> vk_presenter.cpp:501 LogScreenshotStats: TRACE_SCREENSHOT path=/tmp/dark.png size=1920x1080 avg_luma=3.89 max_luma=69 near_black=67.51%\n")
        if summary.screenshots.screenshot_count != 2:
            panic("expected two screenshot stat lines")
        if summary.screenshots.dark_screenshot_count != 1:
            panic("expected one dark screenshot")
        if summary.screenshots.bright_screenshot_count != 1:
            panic("expected one bright screenshot")
        if summary.screenshots.last_screenshot_avg_luma_x100 != 389:
            panic("expected last screenshot average luma")
        if summary.screenshots.last_screenshot_max_luma != 69:
            panic("expected last screenshot max luma")
        if summary.screenshots.last_screenshot_near_black_pct_x100 != 6751:
            panic("expected last near-black percentage")
        if summary.screenshots.min_screenshot_avg_luma_x100 != 389:
            panic("expected minimum screenshot average luma")
        if summary.screenshots.max_screenshot_avg_luma_x100 != 20092:
            panic("expected maximum screenshot average luma")
        if summary.suspicion.suspicious_score != 1:
            panic("expected dark screenshot to mark suspicion")


@test
def ufc_trace_parser_summarizes_black_watchdog_stats() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_BLACK_WATCHDOG_FIXTURE)
        if summary.watchdog.black_watchdog_count != 4:
            panic("expected four watchdog lines")
        if summary.watchdog.black_watchdog_gameonly_count != 2:
            panic("expected two game-only watchdog lines")
        if summary.watchdog.black_watchdog_frameimage_count != 2:
            panic("expected two frame-image watchdog lines")
        if summary.watchdog.black_watchdog_withoverlays_count != 0:
            panic("expected no overlay watchdog lines")
        if summary.watchdog.black_watchdog_black_count != 3:
            panic("expected three black watchdog observations")
        if summary.watchdog.black_watchdog_nonblack_gameonly_count != 1:
            panic("expected one nonblack game-only proof frame")
        if summary.watchdog.black_watchdog_persistent_abort_count != 1:
            panic("expected one persistent watchdog abort")
        if summary.watchdog.black_watchdog_upstream_guest_black_count != 1:
            panic("expected one upstream guest-black classification")
        if summary.watchdog.black_watchdog_vulkan_black_guest_nonblack_count != 0:
            panic("expected no guest-nonblack/vulkan-black classification")
        if summary.watchdog.last_black_watchdog_stage != black_watchdog_stage_frameimage():
            panic("expected last watchdog stage to be frame image")
        if summary.watchdog.last_black_watchdog_frame != 5783:
            panic("expected last watchdog frame")
        if summary.watchdog.last_black_watchdog_consecutive != 3:
            panic("expected last watchdog consecutive count")
        if summary.watchdog.last_black_watchdog_avg_luma_x100 != 0:
            panic("expected black watchdog average luma")
        if summary.watchdog.last_black_watchdog_max_luma != 0:
            panic("expected black watchdog max luma")
        if summary.watchdog.last_black_watchdog_near_black_pct_x100 != 10000:
            panic("expected black watchdog near-black percentage")
        if summary.watchdog.last_black_watchdog_last_writer != black_watchdog_writer_bind_storage_videoout():
            panic("expected storage-videoout writer")
        if summary.watchdog.last_black_watchdog_last_writer_seq != 44:
            panic("expected writer sequence")
        if summary.watchdog.last_black_watchdog_last_writer_addr != 0x27eca0000:
            panic("expected writer address")
        if summary.watchdog.last_black_watchdog_videoout_addr != 0x27eca0000:
            panic("expected videoout address")
        if summary.watchdog.last_black_watchdog_image_id != 1:
            panic("expected image id")


@test
def ufc_trace_black_screen_diagnosis_classifies_watchdog_splits() -> void can[Abort.Panic]:
    can Abort.Panic:
        empty_summary: RenderCheckpoint = empty_checkpoint()
        absent: BlackScreenDiagnosis = ufc_trace_black_screen_diagnosis(empty_summary)
        if absent.kind != black_screen_kind_absent():
            panic("expected absent black-screen diagnosis")
        if absent.avoid_long_run:
            panic("expected absent diagnosis to allow normal run policy")

        upstream_summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_BLACK_WATCHDOG_FIXTURE)
        upstream: BlackScreenDiagnosis = ufc_trace_black_screen_diagnosis(upstream_summary)
        if upstream.kind != black_screen_kind_upstream_guest_black():
            panic("expected upstream guest-black diagnosis")
        if upstream.last_writer_label != "BindStorageVideoOut":
            panic("expected storage-videoout writer label")
        if not upstream.avoid_long_run:
            panic("expected upstream black diagnosis to avoid long runs")

        source_summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_BLACK_WATCHDOG_GUEST_NONBLACK_FIXTURE)
        source: BlackScreenDiagnosis = ufc_trace_black_screen_diagnosis(source_summary)
        if source.kind != black_screen_kind_vulkan_source_black():
            panic("expected Vulkan source black diagnosis")
        if source.last_writer_label != "FillBuffer":
            panic("expected fill-buffer writer label")
        if not source.avoid_long_run:
            panic("expected Vulkan source black diagnosis to avoid long runs")


@test
def ufc_trace_fmask_risk_recommends_targeted_profiles() -> void can[Abort.Panic]:
    can Abort.Panic:
        decompress_summary: mutable RenderCheckpoint = empty_checkpoint()
        decompress_summary.metadata.fmask_decompress_missing_mrt1_count <- 1
        decompress_summary.suspicion.suspicious_score <- 1
        decompress_risk: FmaskRisk = ufc_trace_fmask_risk(decompress_summary)
        if decompress_risk.level != fmask_risk_medium():
            panic("expected decompress-only risk to be medium")
        if decompress_risk.recommended_profile.name != fmask_in_place_profile().name:
            panic("expected fmask in-place recommendation")

        compositor_summary: mutable RenderCheckpoint = empty_checkpoint()
        compositor_summary.bindings.compositor_null_layer_count <- 1
        compositor_risk: FmaskRisk = ufc_trace_fmask_risk(compositor_summary)
        if compositor_risk.level != fmask_risk_medium():
            panic("expected compositor-only risk to be medium")
        if compositor_risk.recommended_profile.name != compositor_null_layer_profile().name:
            panic("expected compositor null-layer recommendation")

        alias_summary: mutable RenderCheckpoint = empty_checkpoint()
        alias_summary.metadata.fmask_cmask_alias_count <- 1
        alias_risk: FmaskRisk = ufc_trace_fmask_risk(alias_summary)
        if alias_risk.level != fmask_risk_medium():
            panic("expected alias-only risk to be medium")
        if alias_risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected fmask null-read recommendation for alias risk")

        mixed_summary: mutable RenderCheckpoint = empty_checkpoint()
        mixed_summary.metadata.metadata_read_hits_last_fmask_count <- 1
        mixed_summary.metadata.fmask_decompress_missing_mrt1_count <- 1
        mixed_summary.bindings.compositor_null_layer_count <- 1
        mixed_risk: FmaskRisk = ufc_trace_fmask_risk(mixed_summary)
        if mixed_risk.level != fmask_risk_high():
            panic("expected mixed risk to be high")
        if mixed_risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected metadata-hit recommendation to take priority")

        missing_mrt1_summary: mutable RenderCheckpoint = empty_checkpoint()
        missing_mrt1_summary.metadata.fmask_cmask_alias_count <- 1
        missing_mrt1_summary.metadata.fmask_decompress_missing_mrt1_count <- 1
        missing_mrt1_risk: FmaskRisk = ufc_trace_fmask_risk(missing_mrt1_summary)
        if missing_mrt1_risk.recommended_profile.name != fmask_in_place_profile().name:
            panic("expected missing mrt1 to recommend fmask in-place")


@test
def ufc_trace_fmask_metadata_classifier_marks_single_sample_alias() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: mutable RenderCheckpoint = empty_checkpoint()
        summary.passes.last_render_samples <- 1
        summary.metadata.last_fmask_addr <- 0x26f408000
        summary.metadata.last_cmask_addr <- 0x26f408000
        metadata_class: FmaskMetadataClass = ufc_trace_fmask_metadata_class(summary)
        if metadata_class.kind != fmask_metadata_single_sample_alias():
            panic("expected single-sample alias class")
        if not metadata_class.suspicious:
            panic("expected single-sample alias to be suspicious")

        separated: mutable RenderCheckpoint = empty_checkpoint()
        separated.passes.last_render_samples <- 4
        separated.metadata.last_fmask_addr <- 0x26f408000
        separated.metadata.last_cmask_addr <- 0x26f400000
        separated_class: FmaskMetadataClass = ufc_trace_fmask_metadata_class(separated)
        if separated_class.kind != fmask_metadata_separate():
            panic("expected separate metadata class")
        if separated_class.suspicious:
            panic("expected separate metadata to be non-suspicious")


@test
def ufc_trace_profiles_keep_safe_timeout_defaults() -> void can[Abort.Panic]:
    can Abort.Panic:
        if baseline_safe_profile().name != "baseline-safe":
            panic("expected baseline profile name")
        if existing_log_profile().name != "existing-log":
            panic("expected existing-log profile name")
        if videoout_storage_force_color_profile().name != "videoout-storage-force-color":
            panic("expected videoout storage force-color profile name")
        if videoout_source_force_colors_profile().name != "videoout-source-force-colors":
            panic("expected videoout source force-colors profile name")
        if fmask_null_read_profile().name != "fmask-null-read":
            panic("expected fmask null-read profile name")
        if fmask_in_place_profile().name != "fmask-in-place":
            panic("expected fmask in-place profile name")
        if compositor_null_layer_profile().name != "compositor-null-layer":
            panic("expected compositor null-layer profile name")
        if videoout_unorm_profile().name != "videoout-unorm":
            panic("expected videoout unorm profile name")
        if fmask_in_place_videoout_unorm_profile().name != "fmask-in-place-videoout-unorm":
            panic("expected combined fmask/videoout profile name")
        if fmask_in_place_probe_profile().name != "fmask-in-place-20s":
            panic("expected fmask probe profile name")
        if fmask_in_place_videoout_unorm_probe_profile().name != "fmask-in-place-videoout-unorm-20s":
            panic("expected combined probe profile name")
        if baseline_safe_profile().timeout_ms != 8000:
            panic("expected baseline timeout")
        if existing_log_profile().timeout_ms != 0:
            panic("expected existing-log timeout")
        if videoout_storage_force_color_profile().timeout_ms != 8000:
            panic("expected videoout storage force-color timeout")
        if videoout_source_force_colors_profile().timeout_ms != 8000:
            panic("expected videoout source force-colors timeout")
        if baseline_safe_profile().null_fmask_reads or baseline_safe_profile().fmask_decompress_in_place or baseline_safe_profile().compositor_null_layer or baseline_safe_profile().videoout_unorm:
            panic("expected baseline to have no experiment toggles")
        if existing_log_profile().null_fmask_reads or existing_log_profile().fmask_decompress_in_place or existing_log_profile().compositor_null_layer or existing_log_profile().videoout_unorm:
            panic("expected existing-log to have no experiment toggles")
        if videoout_storage_force_color_profile().null_fmask_reads or videoout_storage_force_color_profile().fmask_decompress_in_place or videoout_storage_force_color_profile().compositor_null_layer or videoout_storage_force_color_profile().videoout_unorm:
            panic("expected videoout force-color profile to use native env only")
        if videoout_source_force_colors_profile().null_fmask_reads or videoout_source_force_colors_profile().fmask_decompress_in_place or videoout_source_force_colors_profile().compositor_null_layer or videoout_source_force_colors_profile().videoout_unorm:
            panic("expected videoout source force-colors profile to use native env only")
        if fmask_null_read_profile().timeout_ms != 8000:
            panic("expected fmask null-read timeout")
        if not fmask_null_read_profile().null_fmask_reads:
            panic("expected fmask null-read flag")
        if fmask_in_place_profile().timeout_ms != 8000:
            panic("expected fmask in-place timeout")
        if not fmask_in_place_profile().fmask_decompress_in_place:
            panic("expected fmask in-place flag")
        if compositor_null_layer_profile().timeout_ms != 8000:
            panic("expected compositor timeout")
        if not compositor_null_layer_profile().compositor_null_layer:
            panic("expected compositor null-layer flag")
        if videoout_unorm_profile().timeout_ms != 8000:
            panic("expected videoout timeout")
        if not videoout_unorm_profile().videoout_unorm:
            panic("expected videoout unorm flag")
        if not fmask_in_place_videoout_unorm_profile().fmask_decompress_in_place:
            panic("expected combined profile fmask in-place flag")
        if not fmask_in_place_videoout_unorm_profile().videoout_unorm:
            panic("expected combined profile videoout unorm flag")
        if fmask_in_place_probe_profile().timeout_ms != 20000:
            panic("expected fmask probe timeout")
        if not fmask_in_place_probe_profile().fmask_decompress_in_place:
            panic("expected fmask probe in-place flag")
        if fmask_in_place_videoout_unorm_probe_profile().timeout_ms != 20000:
            panic("expected combined probe timeout")
        if not fmask_in_place_videoout_unorm_probe_profile().videoout_unorm:
            panic("expected combined probe videoout unorm flag")


@test
def ufc_trace_progress_budget_tracks_safe_phases() -> void can[Abort.Panic, Progress.CheckCancel, Progress.Tick]:
    can Abort.Panic, Progress.CheckCancel, Progress.Tick:
        baseline_budget: mutable TraceProgressBudget = ufc_trace_progress_budget_for_profile(baseline_safe_profile())
        if baseline_budget.remaining_steps != 192:
            panic("expected baseline progress steps")
        ufc_trace_progress_tick(baseline_budget.ref[mutable TraceProgressBudget&])
        if baseline_budget.remaining_steps != 191:
            panic("expected baseline progress tick")

        existing_log_budget: TraceProgressBudget = ufc_trace_progress_budget_for_existing_log()
        if existing_log_budget.remaining_steps != 4:
            panic("expected existing-log progress steps")

        probe_budget: TraceProgressBudget = ufc_trace_progress_budget_for_profile(fmask_in_place_probe_profile())
        if probe_budget.remaining_steps != 432:
            panic("expected probe progress steps")


@test
def ufc_trace_parser_handles_empty_logs() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text("")
        if summary.passes.line_count != 1:
            panic("expected one empty line")
        if summary.bindings.image_binding_count != 0:
            panic("expected no image bindings")
        if summary.passes.last_videoout_stage != -1:
            panic("expected missing videoout stage")
        if summary.metadata.last_metadata_read_addr != -1:
            panic("expected missing metadata read address")
        risk: FmaskRisk = ufc_trace_fmask_risk(summary)
        if risk.level != fmask_risk_low():
            panic("expected empty log to be low risk")
        if risk.score != 0:
            panic("expected empty log risk score")
        if risk.avoid_long_run:
            panic("expected empty log not to request long-run avoidance")
