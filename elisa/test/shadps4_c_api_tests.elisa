include "../src/ufc_trace.elisa"
include "ufc_trace_fixture.elisa"

extern shadps4_elisa_probe_value() -> i64


@test
def shadps4_c_api_probe_value_round_trips() -> void can[Abort.Panic]:
    can Abort.Panic:
        probe_value: mutable i64 = 0
        trusted Unsafe.RawExtern:
            probe_value <- shadps4_elisa_probe_value()
        if probe_value != 4242:
            panic("expected shadPS4 C API probe value")


@test
def ufc_trace_parser_summarizes_render_checkpoints() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_FIXTURE)
        if summary.image_binding_count != 1:
            panic("expected one image binding")
        if summary.render_target_count != 1:
            panic("expected one render target")
        if summary.depth_target_count != 1:
            panic("expected one depth target")
        if summary.fmask_decompress_count != 1:
            panic("expected one fmask decompress event")
        if summary.metadata_texture_read_count != 1:
            panic("expected one metadata texture read")
        if summary.fmask_texture_read_count != 1:
            panic("expected one fmask metadata read")
        if summary.cmask_texture_read_count != 0:
            panic("expected no cmask metadata reads")
        if summary.htile_texture_read_count != 0:
            panic("expected no htile metadata reads")
        if summary.unknown_metadata_read_count != 0:
            panic("expected no unknown metadata reads")
        if summary.metadata_register_count != 1:
            panic("expected one metadata register")
        if summary.image_binding_texture_count != 1:
            panic("expected one texture image binding")
        if summary.image_binding_storage_count != 0:
            panic("expected no storage image bindings")
        if summary.image_binding_videoout_storage_count != 0:
            panic("expected no videoout storage image bindings")
        if summary.last_image_binding_id != 5:
            panic("expected last image binding id")
        if summary.last_image_binding_index != 0:
            panic("expected last image binding index")
        if summary.last_image_binding_stage != 1:
            panic("expected last image binding stage")
        if summary.last_image_binding_addr != 0x281120000:
            panic("expected last image binding address")
        if summary.last_image_binding_format_kind != render_format_rgba8_unorm():
            panic("expected last image binding format")
        if summary.last_image_binding_samples != 1:
            panic("expected last image binding samples")
        if summary.last_image_binding_bits != 32:
            panic("expected last image binding bits")
        if summary.last_videoout_stage != 18:
            panic("expected videoout stage 18")
        if summary.last_render_pass != 2160:
            panic("expected render pass 2160")
        if summary.last_depth_pass != 2160:
            panic("expected depth pass 2160")
        if summary.last_fmask_addr != 0x2760f8000:
            panic("expected fmask address")
        if summary.last_cmask_addr != 0x2760f0000:
            panic("expected cmask address")
        if summary.last_htile_addr != 0x272ff0000:
            panic("expected htile address")
        if summary.last_metadata_read_addr != 0x2760f8000:
            panic("expected metadata read address")
        if summary.last_metadata_read_kind != metadata_kind_fmask():
            panic("expected fmask metadata kind")
        if summary.last_render_samples != 4:
            panic("expected render sample count")
        if summary.last_depth_samples != 4:
            panic("expected depth sample count")
        if summary.last_render_bits != 32:
            panic("expected render bit depth")
        if summary.last_depth_bits != 32:
            panic("expected depth bit depth")
        if summary.last_render_format_kind != render_format_b10g11r11():
            panic("expected render format kind")
        if summary.last_depth_format_kind != render_format_d32s8():
            panic("expected depth format kind")
        if summary.last_compute_shader != 0xc455a5aa2c447041:
            panic("expected compute shader hash")
        if summary.last_vertex_shader != 0x1198feb92f4085c4:
            panic("expected vertex shader hash")
        if summary.last_compute_pipeline != 0xa2ca58b5abbba0fc:
            panic("expected compute pipeline hash")
        if summary.last_graphics_pipeline != 0x8274a52bcc15679:
            panic("expected graphics pipeline hash")
        if summary.metadata_read_hits_last_fmask_count != 1:
            panic("expected metadata read to hit last fmask")
        if summary.metadata_read_hits_last_cmask_count != 0:
            panic("expected metadata read to miss last cmask")
        if summary.metadata_read_hits_last_htile_count != 0:
            panic("expected metadata read to miss last htile")
        if summary.fmask_cmask_alias_count != 0:
            panic("expected no fmask/cmask alias in fixture")
        if summary.suspicious_score != 0:
            panic("expected no suspicious score in baseline fixture")
        risk: FmaskRisk = ufc_trace_fmask_risk(summary)
        if risk.level != fmask_risk_medium():
            panic("expected baseline fixture to be medium risk because fmask is sampled")
        if risk.score != 2:
            panic("expected baseline fixture risk score")
        if risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected fmask null-read recommendation")
        if not risk.avoid_long_run:
            panic("expected medium-risk trace to avoid long automated runs")


@test
def ufc_trace_parser_marks_black_screen_adjacent_suspicion() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_SUSPICIOUS_FIXTURE)
        if summary.render_target_count != 1:
            panic("expected one suspicious render target")
        if summary.fmask_cmask_alias_count != 1:
            panic("expected aliased fmask/cmask")
        if summary.fmask_decompress_missing_mrt1_count != 1:
            panic("expected missing mrt1 decompress")
        if summary.compositor_null_layer_count != 1:
            panic("expected compositor null layer")
        if summary.image_binding_null_count != 1:
            panic("expected null image binding")
        if summary.null_metadata_action_count != 1:
            panic("expected null metadata action")
        if summary.metadata_read_hits_last_fmask_count != 1:
            panic("expected null metadata read to hit fmask")
        if summary.first_suspicious_pass != 3000:
            panic("expected first suspicious pass")
        if summary.suspicious_score < 5:
            panic("expected multiple suspicious signals")
        risk: FmaskRisk = ufc_trace_fmask_risk(summary)
        if risk.level != fmask_risk_high():
            panic("expected high fmask risk")
        if risk.score < 10:
            panic("expected high fmask risk score")
        if risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected fmask null-read recommendation for metadata hit")
        if not risk.avoid_long_run:
            panic("expected high-risk trace to avoid long automated runs")


@test
def ufc_trace_parser_summarizes_gpu_command_diagnostics() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text(UFC_TRACE_GPU_DIAGNOSTIC_FIXTURE)
        if summary.launch_build_cache_warning_count != 1:
            panic("expected one stale build cache warning")
        if summary.launch_binary_current_count != 1:
            panic("expected current build binary marker")
        if summary.gpu_diagnostic_dump_count != 1:
            panic("expected one gpu diagnostic dump")
        if summary.gpu_command_count != 4:
            panic("expected four gpu command lines")
        if summary.gpu_command_swapchain_count != 1:
            panic("expected one swapchain gpu command")
        if summary.gpu_command_draw_count != 2:
            panic("expected two draw commands")
        if summary.gpu_command_indexed_draw_count != 1:
            panic("expected one indexed draw command")
        if summary.gpu_command_indirect_draw_count != 0:
            panic("expected no indirect draw command")
        if summary.gpu_command_dispatch_count != 1:
            panic("expected one dispatch command")
        if summary.last_gpu_command_serial != 12:
            panic("expected last gpu command serial")
        if summary.last_gpu_draw_vertices != 6:
            panic("expected last direct draw vertex count")
        if summary.last_gpu_draw_indices != 42:
            panic("expected last indexed draw index count")
        if summary.last_gpu_dispatch_x != 16:
            panic("expected last dispatch x")
        if summary.last_gpu_dispatch_y != 8:
            panic("expected last dispatch y")
        if summary.last_gpu_dispatch_z != 1:
            panic("expected last dispatch z")


@test
def ufc_trace_fmask_risk_recommends_targeted_profiles() -> void can[Abort.Panic]:
    can Abort.Panic:
        decompress_summary: mutable RenderCheckpoint = empty_checkpoint()
        decompress_summary.fmask_decompress_missing_mrt1_count <- 1
        decompress_summary.suspicious_score <- 1
        decompress_risk: FmaskRisk = ufc_trace_fmask_risk(decompress_summary)
        if decompress_risk.level != fmask_risk_medium():
            panic("expected decompress-only risk to be medium")
        if decompress_risk.recommended_profile.name != fmask_in_place_profile().name:
            panic("expected fmask in-place recommendation")

        compositor_summary: mutable RenderCheckpoint = empty_checkpoint()
        compositor_summary.compositor_null_layer_count <- 1
        compositor_risk: FmaskRisk = ufc_trace_fmask_risk(compositor_summary)
        if compositor_risk.level != fmask_risk_medium():
            panic("expected compositor-only risk to be medium")
        if compositor_risk.recommended_profile.name != compositor_null_layer_profile().name:
            panic("expected compositor null-layer recommendation")

        alias_summary: mutable RenderCheckpoint = empty_checkpoint()
        alias_summary.fmask_cmask_alias_count <- 1
        alias_risk: FmaskRisk = ufc_trace_fmask_risk(alias_summary)
        if alias_risk.level != fmask_risk_medium():
            panic("expected alias-only risk to be medium")
        if alias_risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected fmask null-read recommendation for alias risk")

        mixed_summary: mutable RenderCheckpoint = empty_checkpoint()
        mixed_summary.metadata_read_hits_last_fmask_count <- 1
        mixed_summary.fmask_decompress_missing_mrt1_count <- 1
        mixed_summary.compositor_null_layer_count <- 1
        mixed_risk: FmaskRisk = ufc_trace_fmask_risk(mixed_summary)
        if mixed_risk.level != fmask_risk_high():
            panic("expected mixed risk to be high")
        if mixed_risk.recommended_profile.name != fmask_null_read_profile().name:
            panic("expected metadata-hit recommendation to take priority")

        missing_mrt1_summary: mutable RenderCheckpoint = empty_checkpoint()
        missing_mrt1_summary.fmask_cmask_alias_count <- 1
        missing_mrt1_summary.fmask_decompress_missing_mrt1_count <- 1
        missing_mrt1_risk: FmaskRisk = ufc_trace_fmask_risk(missing_mrt1_summary)
        if missing_mrt1_risk.recommended_profile.name != fmask_in_place_profile().name:
            panic("expected missing mrt1 to recommend fmask in-place")


@test
def ufc_trace_fmask_metadata_classifier_marks_single_sample_alias() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: mutable RenderCheckpoint = empty_checkpoint()
        summary.last_render_samples <- 1
        summary.last_fmask_addr <- 0x26f408000
        summary.last_cmask_addr <- 0x26f408000
        metadata_class: FmaskMetadataClass = ufc_trace_fmask_metadata_class(summary)
        if metadata_class.kind != fmask_metadata_single_sample_alias():
            panic("expected single-sample alias class")
        if not metadata_class.suspicious:
            panic("expected single-sample alias to be suspicious")

        separated: mutable RenderCheckpoint = empty_checkpoint()
        separated.last_render_samples <- 4
        separated.last_fmask_addr <- 0x26f408000
        separated.last_cmask_addr <- 0x26f400000
        separated_class: FmaskMetadataClass = ufc_trace_fmask_metadata_class(separated)
        if separated_class.kind != fmask_metadata_separate():
            panic("expected separate metadata class")
        if separated_class.suspicious:
            panic("expected separate metadata to be non-suspicious")


@test
def ufc_trace_profiles_keep_safe_timeout_defaults() -> void can[Abort.Panic]:
    can Abort.Panic:
        if baseline_safe_profile().name != "baseline-safe":
            panic("expected baseline profile name")
        if existing_log_profile().name != "existing-log":
            panic("expected existing-log profile name")
        if fmask_null_read_profile().name != "fmask-null-read":
            panic("expected fmask null-read profile name")
        if fmask_in_place_profile().name != "fmask-in-place":
            panic("expected fmask in-place profile name")
        if compositor_null_layer_profile().name != "compositor-null-layer":
            panic("expected compositor null-layer profile name")
        if videoout_unorm_profile().name != "videoout-unorm":
            panic("expected videoout unorm profile name")
        if baseline_safe_profile().timeout_ms != 8000:
            panic("expected baseline timeout")
        if existing_log_profile().timeout_ms != 0:
            panic("expected existing-log timeout")
        if baseline_safe_profile().null_fmask_reads or baseline_safe_profile().fmask_decompress_in_place or baseline_safe_profile().compositor_null_layer or baseline_safe_profile().videoout_unorm:
            panic("expected baseline to have no experiment toggles")
        if existing_log_profile().null_fmask_reads or existing_log_profile().fmask_decompress_in_place or existing_log_profile().compositor_null_layer or existing_log_profile().videoout_unorm:
            panic("expected existing-log to have no experiment toggles")
        if fmask_null_read_profile().timeout_ms != 8000:
            panic("expected fmask null-read timeout")
        if not fmask_null_read_profile().null_fmask_reads:
            panic("expected fmask null-read flag")
        if fmask_in_place_profile().timeout_ms != 8000:
            panic("expected fmask in-place timeout")
        if not fmask_in_place_profile().fmask_decompress_in_place:
            panic("expected fmask in-place flag")
        if compositor_null_layer_profile().timeout_ms != 8000:
            panic("expected compositor timeout")
        if not compositor_null_layer_profile().compositor_null_layer:
            panic("expected compositor null-layer flag")
        if videoout_unorm_profile().timeout_ms != 8000:
            panic("expected videoout timeout")
        if not videoout_unorm_profile().videoout_unorm:
            panic("expected videoout unorm flag")


@test
def ufc_trace_parser_handles_empty_logs() -> void can[Abort.Panic]:
    can Abort.Panic:
        summary: RenderCheckpoint = ufc_trace_analyze_text("")
        if summary.line_count != 1:
            panic("expected one empty line")
        if summary.image_binding_count != 0:
            panic("expected no image bindings")
        if summary.last_videoout_stage != -1:
            panic("expected missing videoout stage")
        if summary.last_metadata_read_addr != -1:
            panic("expected missing metadata read address")
        risk: FmaskRisk = ufc_trace_fmask_risk(summary)
        if risk.level != fmask_risk_low():
            panic("expected empty log to be low risk")
        if risk.score != 0:
            panic("expected empty log risk score")
        if risk.avoid_long_run:
            panic("expected empty log not to request long-run avoidance")
